<AranshInterface>:
    orientation: 'vertical'
    canvas.before:
        Color:
            rgba: 0.1, 0.1, 0.1, 1  # Dark background
        Rectangle:
            pos: self.pos
            size: self.size
    
    Label:
        text: "ARANSH AI"
        font_size: '40sp'
        color: 0, 0.7, 1, 1  # Neon Blue
